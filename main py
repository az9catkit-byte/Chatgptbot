@dp.message()
async def handle_text(message: types.Message):
    user_id = message.from_user.id
    await update_user_activity(user_id)

    if message.chat.type != "private":
        await save_group_info(message.chat)
        if not is_bot_mentioned(message):
            return

    # Сообщение от админа, управляющего пользователем
    if user_id in admin_sessions and user_id in control_sessions:
        target_id = control_sessions[user_id]
        try:
            await bot.send_message(target_id, message.text)
            await message.reply(f"✅ Сообщение отправлено пользователю `{target_id}`.")
        except Exception as e:
            await message.reply(f"❌ Не удалось отправить сообщение: {e}")
        return

    # Сообщение от админа, управляющего группой
    if user_id in admin_sessions and user_id in group_control_sessions:
        target_chat_id = group_control_sessions[user_id]
        try:
            await bot.send_message(target_chat_id, message.text)
            await message.reply(f"✅ Сообщение отправлено в группу `{target_chat_id}`.")
        except Exception as e:
            await message.reply(f"❌ Не удалось отправить сообщение в группу: {e}")
        return

    # Сообщение от управляемого пользователя
    for admin_id, target_id in control_sessions.items():
        if user_id == target_id:
            await bot.send_message(admin_id, f"💬 Сообщение от пользователя `{user_id}`:\n\n{message.text}")
            await message.reply("📨 Ваше сообщение передано администратору. Ожидайте ответа.")
            return

    # Сообщение из управляемой группы
    for admin_id, target_chat_id in group_control_sessions.items():
        if message.chat.id == target_chat_id:
            sender_name = message.from_user.full_name or "Неизвестный"
            header = f"👤 **От отправителя:** {sender_name} (`{user_id}`)\n\n"
            await bot.send_message(admin_id, header + message.text)
            await message.reply("📨 Сообщение передано администратору.")
            return

    # Обычный ответ через ИИ
    user_text = message.text
    history = await load_history(user_id)
    history.append({"role": "user", "content": user_text})

    try:
        response = await groq_client.chat.completions.create(
            model="llama-3.1-8b-instant",
            messages=history
        )
        reply = response.choices[0].message.content

        history.append({"role": "assistant", "content": reply})
        if len(history) > MAX_HISTORY_LENGTH:
            history = history[-MAX_HISTORY_LENGTH:]

        await save_history(user_id, history)
        await message.reply(reply)

    except Exception as e:
        if history and history[-1]["role"] == "user":
            history.pop()
        await save_history(user_id, history)
        await message.reply(f"❌ Ошибка: {e}")


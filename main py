import asyncio
import json
import os
import re
import aiofiles
from aiogram import Bot, Dispatcher, types, F
from aiogram.filters import Command, StateFilter
from aiogram.fsm.context import FSMContext
from aiogram.fsm.state import State, StatesGroup
from aiogram.fsm.storage.memory import MemoryStorage
from groq import AsyncGroq
import PyPDF2
from docx import Document
import yt_dlp

# === НАСТРОЙКИ (ИМПОРТ ИЗ config.py) ===
try:
    from config import TELEGRAM_BOT_TOKEN, GROQ_API_KEY, ADMIN_PASSWORD
except ImportError:
    raise ImportError("Не найден файл config.py или в нём отсутствуют необходимые переменные")

if not TELEGRAM_BOT_TOKEN or not GROQ_API_KEY or not ADMIN_PASSWORD:
    raise ValueError("TELEGRAM_BOT_TOKEN, GROQ_API_KEY и ADMIN_PASSWORD не могут быть пустыми в config.py")

bot = Bot(token=TELEGRAM_BOT_TOKEN)
storage = MemoryStorage()
dp = Dispatcher(storage=storage)
groq_client = AsyncGroq(api_key=GROQ_API_KEY)

# Папки
DATA_DIR = "user_data"
DOWNLOADS_DIR = "downloads"
os.makedirs(DATA_DIR, exist_ok=True)
os.makedirs(DOWNLOADS_DIR, exist_ok=True)

MAX_HISTORY_LENGTH = 10

# === ХРАНЕНИЕ СЕССИЙ АДМИНИСТРАТОРА ===
admin_sessions = set()

# === СОСТОЯНИЯ ДЛЯ FSM (ВВОД ПАРОЛЯ) ===
class AdminAuth(StatesGroup):
    waiting_for_password = State()

# === ФУНКЦИИ ДЛЯ ИСТОРИИ ===
def get_user_file_path(user_id: int) -> str:
    return os.path.join(DATA_DIR, f"{user_id}.json")

async def load_history(user_id: int) -> list:
    file_path = get_user_file_path(user_id)
    if not os.path.exists(file_path):
        return []
    try:
        async with aiofiles.open(file_path, 'r', encoding='utf-8') as f:
            content = await f.read()
            return json.loads(content)
    except (json.JSONDecodeError, FileNotFoundError):
        return []

async def save_history(user_id: int, history: list):
    file_path = get_user_file_path(user_id)
    async with aiofiles.open(file_path, 'w', encoding='utf-8') as f:
        await f.write(json.dumps(history, ensure_ascii=False, indent=2))

# === ФУНКЦИИ ДЛЯ ЧТЕНИЯ ФАЙЛОВ ===
async def download_file(file_id: str, destination: str):
    file = await bot.get_file(file_id)
    await bot.download_file(file.file_path, destination)

def extract_text_from_txt(file_path: str) -> str:
    with open(file_path, 'r', encoding='utf-8') as f:
        return f.read()

def extract_text_from_pdf(file_path: str) -> str:
    text = ""
    with open(file_path, 'rb') as f:
        reader = PyPDF2.PdfReader(f)
        for page in reader.pages:
            text += page.extract_text() or ""
    return text

def extract_text_from_docx(file_path: str) -> str:
    doc = Document(file_path)
    return "\n".join([p.text for p in doc.paragraphs])

async def process_document(message: types.Message) -> tuple[str, str]:
    document = message.document
    file_name = document.file_name.lower()
    file_id = document.file_id
    file_path = os.path.join(DOWNLOADS_DIR, f"{message.from_user.id}_{file_id}_{file_name}")

    await download_file(file_id, file_path)

    extracted_text = ""
    if file_name.endswith('.txt'):
        extracted_text = extract_text_from_txt(file_path)
    elif file_name.endswith('.pdf'):
        extracted_text = extract_text_from_pdf(file_path)
    elif file_name.endswith('.docx'):
        extracted_text = extract_text_from_docx(file_path)
    else:
        os.remove(file_path)
        raise ValueError("Неподдерживаемый формат. Можно: TXT, PDF, DOCX.")

    os.remove(file_path)
    return file_name, extracted_text.strip()

# === ФУНКЦИЯ ДЛЯ СКАЧИВАНИЯ ВИДЕО ===
async def download_video(url: str, user_id: int) -> str | None:
    ydl_opts = {
        'format': 'best[height<=720]',
        'outtmpl': os.path.join(DOWNLOADS_DIR, f'{user_id}_%(title)s.%(ext)s'),
        'quiet': True,
        'no_warnings': True,
        'max_filesize': 50 * 1024 * 1024,
    }
    try:
        with yt_dlp.YoutubeDL(ydl_opts) as ydl:
            info = ydl.extract_info(url, download=True)
            filename = ydl.prepare_filename(info)
            base, _ = os.path.splitext(filename)
            for ext in ['.mp4', '.webm', '.mkv']:
                potential_path = base + ext
                if os.path.exists(potential_path):
                    return potential_path
            return None
    except Exception as e:
        print(f"Ошибка скачивания: {e}")
        return None

# === ХЕНДЛЕРЫ КОМАНД ===
@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    await message.answer(
        "👋 Привет! Я бот с Groq и памятью в файлах.\n\n"
        "📝 **Возможности:**\n"
        "— Отвечаю на текстовые сообщения с учётом истории.\n"
        "— Принимаю документы (TXT, PDF, DOCX) и анализирую их содержимое.\n"
        "— Скачиваю видео с YouTube, TikTok и других сайтов. Просто пришли мне ссылку или используй /dl <ссылка>.\n"
        "— Если пришлёте фото с подписью, я запомню контекст.\n\n"
        "🔹 /clear — очистить историю\n"
        "🔹 /history — показать историю\n"
        "🔹 /dl <ссылка> — скачать видео\n"
        "🔹 Отправьте `administratormode` для входа в режим администратора"
    )

@dp.message(Command("clear"))
async def cmd_clear(message: types.Message):
    user_id = message.from_user.id
    file_path = get_user_file_path(user_id)
    if os.path.exists(file_path):
        os.remove(file_path)
    await message.reply("🧹 История диалога очищена.")

@dp.message(Command("history"))
async def cmd_history(message: types.Message):
    user_id = message.from_user.id
    history = await load_history(user_id)
    if not history:
        await message.reply("📭 История пуста.")
        return
    text = "📜 **Последние сообщения:**\n"
    for msg in history[-6:]:
        role = "👤" if msg["role"] == "user" else "🤖"
        content = msg["content"][:100] + ("..." if len(msg["content"]) > 100 else "")
        text += f"{role} {content}\n"
    await message.reply(text)

# === АДМИНИСТРАТИВНЫЙ ВХОД ПО КЛЮЧЕВОМУ СЛОВУ ===
@dp.message(F.text.lower() == "administratormode")
async def admin_mode_trigger(message: types.Message, state: FSMContext):
    user_id = message.from_user.id

    # Если уже админ — выходим
    if user_id in admin_sessions:
        admin_sessions.remove(user_id)
        await message.reply("🔓 Вы вышли из режима администратора.")
        return

    # Иначе запрашиваем пароль
    await message.reply("🔐 Введите пароль администратора:")
    await state.set_state(AdminAuth.waiting_for_password)

@dp.message(StateFilter(AdminAuth.waiting_for_password))
async def process_password(message: types.Message, state: FSMContext):
    user_id = message.from_user.id
    if message.text == ADMIN_PASSWORD:
        admin_sessions.add(user_id)
        await message.reply("✅ Пароль верный. Вы вошли в режим администратора.\nДоступные команды:\n/users — список пользователей\n/history_admin <user_id> — история пользователя")
    else:
        await message.reply("❌ Неверный пароль.")
    await state.clear()

# Команда /users (только для админов)
@dp.message(Command("users"))
async def cmd_users(message: types.Message):
    if message.from_user.id not in admin_sessions:
        await message.reply("⛔ У вас нет прав для этой команды.")
        return

    try:
        files = os.listdir(DATA_DIR)
        user_ids = [int(f.replace('.json', '')) for f in files if f.endswith('.json')]
        if not user_ids:
            await message.reply("📭 Нет ни одного пользователя с историей.")
            return
        text = "👥 **Пользователи с историей:**\n"
        for uid in sorted(user_ids)[:30]:
            text += f"• `{uid}`\n"
        if len(user_ids) > 30:
            text += f"\n... и ещё {len(user_ids) - 30}"
        await message.reply(text, parse_mode="Markdown")
    except Exception as e:
        await message.reply(f"❌ Ошибка при чтении списка пользователей: {e}")

# Команда /history_admin <user_id> (только для админов)
@dp.message(Command("history_admin"))
async def cmd_history_admin(message: types.Message):
    if message.from_user.id not in admin_sessions:
        await message.reply("⛔ У вас нет прав для этой команды.")
        return

    args = message.text.split()
    if len(args) != 2:
        await message.reply("Используйте: /history_admin <user_id>")
        return

    try:
        target_id = int(args[1])
    except ValueError:
        await message.reply("ID пользователя должен быть числом.")
        return

    history = await load_history(target_id)
    if not history:
        await message.reply(f"📭 У пользователя {target_id} нет истории.")
        return

    text = f"📜 **История пользователя {target_id}:**\n"
    for msg in history[-10:]:
        role = "👤" if msg["role"] == "user" else "🤖"
        content = msg["content"].replace('\n', ' ')[:150]
        if len(msg["content"]) > 150:
            content += "..."
        text += f"{role} {content}\n"
    await message.reply(text)

# === ОБРАБОТЧИК СКАЧИВАНИЯ ПО КОМАНДЕ ===
@dp.message(Command("dl"))
async def cmd_download(message: types.Message):
    url = message.text.replace('/dl', '').strip()
    if not url:
        await message.reply("Пожалуйста, укажите ссылку после команды. Пример: /dl https://youtu.be/...")
        return

    await message.reply("⏳ Скачиваю видео, подождите...")
    file_path = await download_video(url, message.from_user.id)

    if file_path and os.path.exists(file_path):
        try:
            with open(file_path, 'rb') as video:
                await bot.send_video(message.chat.id, video)
        except Exception as e:
            await message.reply(f"❌ Ошибка отправки видео: {e}")
        finally:
            os.remove(file_path)
    else:
        await message.reply("❌ Не удалось скачать видео. Возможно, ссылка недействительна или видео слишком большое.")

# === ОБРАБОТЧИК ССЫЛОК В ТЕКСТЕ ===
URL_REGEX = re.compile(r'(https?://[^\s]+)')

@dp.message(lambda message: message.text and URL_REGEX.search(message.text))
async def handle_url_message(message: types.Message):
    urls = URL_REGEX.findall(message.text)
    for url in urls:
        if any(domain in url for domain in ['youtu.be', 'youtube.com', 'tiktok.com']):
            await message.reply(f"🔗 Обнаружена ссылка. Скачиваю {url}...")
            file_path = await download_video(url, message.from_user.id)

            if file_path and os.path.exists(file_path):
                try:
                    with open(file_path, 'rb') as video:
                        await bot.send_video(message.chat.id, video)
                except Exception as e:
                    await message.reply(f"❌ Ошибка отправки видео: {e}")
                finally:
                    os.remove(file_path)
            else:
                await message.reply("❌ Не удалось скачать видео.")
            break

# === ОБРАБОТЧИК ДОКУМЕНТОВ ===
@dp.message(lambda message: message.document is not None)
async def handle_document(message: types.Message):
    user_id = message.from_user.id
    await message.reply("📄 Читаю документ, подождите...")

    try:
        file_name, extracted_text = await process_document(message)
        if not extracted_text:
            await message.reply("❌ Не удалось извлечь текст из файла.")
            return

        max_chars = 5000
        if len(extracted_text) > max_chars:
            extracted_text = extracted_text[:max_chars] + "\n... (текст обрезан)"

        prompt = f"Пользователь прислал файл '{file_name}' со следующим содержимым:\n\n{extracted_text}\n\nОтветь на вопросы по этому документу или дай краткое резюме."

        history = await load_history(user_id)
        history.append({"role": "user", "content": prompt})

        response = await groq_client.chat.completions.create(
            model="llama-3.1-8b-instant",
            messages=history
        )
        reply = response.choices[0].message.content

        history.append({"role": "assistant", "content": reply})
        if len(history) > MAX_HISTORY_LENGTH:
            history = history[-MAX_HISTORY_LENGTH:]
        await save_history(user_id, history)

        await message.reply(reply)

    except ValueError as e:
        await message.reply(f"❌ {str(e)}")
    except Exception as e:
        await message.reply(f"❌ Ошибка обработки документа: {e}")

# === ОБРАБОТЧИК ФОТО ===
@dp.message(lambda message: message.photo is not None)
async def handle_photo(message: types.Message):
    user_id = message.from_user.id
    caption = message.caption or ""

    history = await load_history(user_id)

    user_msg = f"[Пользователь прислал фото]"
    if caption:
        user_msg += f" с подписью: {caption}"
    else:
        user_msg += " без подписи."

    history.append({"role": "user", "content": user_msg})

    reply = "📷 Я получил ваше фото, но пока не умею анализировать изображения. Могу ответить на вопросы по тексту или документам."
    history.append({"role": "assistant", "content": reply})

    if len(history) > MAX_HISTORY_LENGTH:
        history = history[-MAX_HISTORY_LENGTH:]

    await save_history(user_id, history)
    await message.reply(reply)

# === ОБРАБОТЧИК ТЕКСТОВЫХ СООБЩЕНИЙ ===
@dp.message()
async def handle_text(message: types.Message):
    user_id = message.from_user.id
    user_text = message.text

    history = await load_history(user_id)
    history.append({"role": "user", "content": user_text})

    try:
        response = await groq_client.chat.completions.create(
            model="llama-3.1-8b-instant",
            messages=history
        )
        reply = response.choices[0].message.content

        history.append({"role": "assistant", "content": reply})
        if len(history) > MAX_HISTORY_LENGTH:
            history = history[-MAX_HISTORY_LENGTH:]

        await save_history(user_id, history)
        await message.reply(reply)

    except Exception as e:
        if history and history[-1]["role"] == "user":
            history.pop()
        await save_history(user_id, history)
        await message.reply(f"❌ Ошибка: {e}")

# === ЗАПУСК ===
async def main():
    await dp.start_polling(bot)

if __name__ == '__main__':
    print("Бот запущен...")
    asyncio.run(main())

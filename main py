# === АДМИНИСТРАТИВНЫЙ ВХОД (ТОЛЬКО В ЛИЧКЕ) ===
@dp.message(F.text.lower() == "administratormode")
async def admin_mode_trigger(message: types.Message, state: FSMContext):
    await update_user_activity(message.from_user.id)
    if message.chat.type != "private":
        await message.reply("⛔ Режим администратора доступен только в личных сообщениях.")
        return

    user_id = message.from_user.id
    if user_id in admin_sessions:
        admin_sessions.remove(user_id)
        if user_id in control_sessions:
            del control_sessions[user_id]
        if user_id in group_control_sessions:
            del group_control_sessions[user_id]
        await message.reply("🔓 Вы вышли из режима администратора.")
        return

    await message.reply("🔐 Введите пароль администратора:")
    await state.set_state(AdminAuth.waiting_for_password)

@dp.message(StateFilter(AdminAuth.waiting_for_password))
async def process_password(message: types.Message, state: FSMContext):
    await update_user_activity(message.from_user.id)
    if message.chat.type != "private":
        await state.clear()
        return

    user_id = message.from_user.id
    if message.text == ADMIN_PASSWORD:
        admin_sessions.add(user_id)
        await message.reply(
            "✅ Пароль верный. Вы вошли в режим администратора.\n\n"
            "Доступные команды:\n"
            "/users — список пользователей\n"
            "/history_admin <user_id> — история пользователя\n"
            "/control <user_id> — взять пользователя под ручное управление\n"
            "/control stop — завершить управление\n"
            "/online — список пользователей с онлайн-статусом\n"
            "/groups — список групп бота\n"
            "/group_connect <chat_id> — управлять группой\n"
            "/group_connect stop — завершить управление группой"
        )
    else:
        await message.reply("❌ Неверный пароль.")
    await state.clear()

# === КОМАНДЫ АДМИНИСТРАТОРА (ТОЛЬКО В ЛИЧКЕ) ===
def require_private_and_admin(func):
    async def wrapper(message: types.Message, *args, **kwargs):
        await update_user_activity(message.from_user.id)
        if message.chat.type != "private":
            await message.reply("⛔ Эта команда доступна только в личных сообщениях.")
            return
        if message.from_user.id not in admin_sessions:
            await message.reply("⛔ У вас нет прав для этой команды.")
            return
        return await func(message, *args, **kwargs)
    return wrapper

@dp.message(Command("control"))
@require_private_and_admin
async def cmd_control(message: types.Message):
    admin_id = message.from_user.id
    args = message.text.split()
    if len(args) == 1:
        if admin_id in control_sessions:
            target = control_sessions[admin_id]
            await message.reply(f"🔧 Вы управляете пользователем `{target}`. Для выхода: /control stop")
        else:
            await message.reply("ℹ️ Вы не управляете ни одним пользователем. Используйте /control <user_id>.")
        return

    if args[1].lower() == "stop":
        if admin_id in control_sessions:
            target = control_sessions.pop(admin_id)
            await message.reply(f"🔓 Управление пользователем `{target}` завершено. ИИ снова активен.")
        else:
            await message.reply("ℹ️ Нет активного управления.")
        return

    try:
        target_id = int(args[1])
    except ValueError:
        await message.reply("❌ ID пользователя должен быть числом.")
        return

    control_sessions[admin_id] = target_id
    await message.reply(
        f"🔧 Теперь вы управляете пользователем `{target_id}`.\n"
        f"Все его сообщения будут пересылаться вам. Ваши сообщения будут отправляться ему.\n"
        f"ИИ для этого пользователя отключён.\n"
        f"Для выхода: /control stop"
    )

@dp.message(Command("online"))
@require_private_and_admin
async def cmd_online(message: types.Message):
    activities = await get_all_users_activity()
    if not activities:
        await message.reply("📭 Нет данных об активности пользователей.")
        return

    now = time.time()
    lines = ["👥 **Статус пользователей:**\n"]
    for user_id, last_active in sorted(activities.items(), key=lambda x: x[1], reverse=True):
        delta = now - last_active
        if delta < ONLINE_THRESHOLD:
            status = "🟢 онлайн"
        else:
            status = "🔴 офлайн"
        time_str = time.strftime("%Y-%m-%d %H:%M:%S", time.localtime(last_active))
        lines.append(f"• Пользователь(`{user_id}`): {status} (посл. {time_str})")

    text = "\n".join(lines[:31])
    if len(lines) > 31:
        text += f"\n... и ещё {len(lines)-31}"
    await message.reply(text, parse_mode="Markdown")

